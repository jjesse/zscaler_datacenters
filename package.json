{
  "name": "zscaler-datacenter-lookup",
  "version": "1.0.0",
  "description": "Web app to identify Zscaler datacenter locations from IP addresses",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --testPathPatterns=tests/ --forceExit",
    "test:coverage": "c8 jest --testPathPatterns=tests/ --forceExit",
    "lint": "eslint . --ext .js --ignore-pattern public/"
  },
  "keywords": [
    "zscaler",
    "datacenter",
    "ip-lookup",
    "cenr"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "c8": "^10.1.3",
    "eslint": "^10.0.1",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.7",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "git add"
    ]
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
