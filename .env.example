# Zscaler Datacenter Lookup - Environment Variables
# Copy this file to .env and adjust the values as needed.
# The application can also be configured using docker-compose.yml environment section.

# Port the Express server will listen on (default: 3000)
PORT=3000

# How long to cache Zscaler CENR data in milliseconds (default: 3600000 = 1 hour)
# Increase this value to reduce external API calls; decrease for fresher data.
CACHE_DURATION=3600000

# Node environment (development | production)
NODE_ENV=production
