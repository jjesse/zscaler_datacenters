# Zscaler Datacenter Lookup - Environment Variables
# Copy this file to .env and adjust the values as needed.
# The application can also be configured using docker-compose.yml environment section.

# Port the Express server will listen on (default: 3000)
PORT=3000

# How long to cache Zscaler CENR data in milliseconds (default: 3600000 = 1 hour)
# Increase this value to reduce external API calls; decrease for fresher data.
CACHE_DURATION=3600000

# Node environment (development | production)
NODE_ENV=production

# SSL certificate paths (optional – omit or leave blank to run in HTTP mode)
# To enable HTTPS, place your key and certificate files and set these paths.
# Example: openssl req -x509 -newkey rsa:4096 -keyout certs/key.pem -out certs/cert.pem -days 365 -nodes
# SSL_KEY_PATH=certs/key.pem
# SSL_CERT_PATH=certs/cert.pem

# ZDX API credentials (required only for the /api/zdx/userpath endpoint)
# Obtain a Client ID and Secret from your ZDX Admin Portal (Administration → API Keys).
# ZDX_CLIENT_ID=your-zdx-client-id
# ZDX_CLIENT_SECRET=your-zdx-client-secret

# Trust proxy headers (optional – only set when running behind a trusted reverse proxy)
# Setting this enables X-Forwarded-For / X-Real-IP processing for client IP detection
# and ensures the rate limiter counts requests against the real client IP rather than
# the proxy's IP.  The value is passed directly to Express "trust proxy":
#   - An integer (e.g. 1) trusts that many hops from the right of X-Forwarded-For.
#   - A named preset: "loopback", "linklocal", or "uniquelocal".
# Leave unset (default) for direct/public deployments to prevent IP spoofing.
# TRUST_PROXY=1
